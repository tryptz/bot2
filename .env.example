# ---- Discord ----
# Bot token from the Developer Portal (Bot tab > Reset Token). KEEP THIS SECRET.
DISCORD_TOKEN=your-bot-token-here
# Application (client) ID from the Portal "General Information" tab.
CLIENT_ID=your-application-id-here
# Your test server's ID (right-click the server > Copy Server ID, with Developer Mode on).
# Guild-scoped commands register instantly; leave blank to register globally (~1h to appear).
GUILD_ID=your-server-id-here

# ---- TrypT-hifi backend ----
# Base URL of YOUR running TrypT-hifi (Qobuz-DL) instance.
TRYPT_HIFI_URL=https://tryptify.lol
# Optional: 2-letter country code sent as the Token-Country header (e.g. US, GB).
TRYPT_HIFI_COUNTRY=
# Default download/stream quality: 27=Hi-Res 192k, 7=Hi-Res 96k, 6=CD lossless, 5=MP3 320.
DEFAULT_QUALITY=6

# ---- Bot behavior ----
# Folder (relative to the bot) where /download saves files.
DOWNLOAD_DIR=downloads
